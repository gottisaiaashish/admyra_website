// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  googleId  String?  @unique
  avatar    String?
  username  String?  @unique
  bio       String?
  role      String   @default("student")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  grievances Grievance[]
  comments   Comment[]
  posts      Post[]
  likes      Like[]
  saves      Save[]
  agrees     GrievanceAgree[]
  stories    Story[]
  followers  Follow[] @relation("UserFollowers")
  following  Follow[] @relation("UserFollowing")
}

model Story {
  id        String   @id @default(uuid())
  mediaUrl  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Follow {
  id          String @id @default(uuid())
  followerId  String
  followingId String
  follower    User   @relation("UserFollowing", fields: [followerId], references: [id])
  following   User   @relation("UserFollowers", fields: [followingId], references: [id])
  @@unique([followerId, followingId])
}

model Post {
// ... existing Post fields ...
  id          String   @id @default(uuid())
  type        String   @default("photo") // "reel" or "photo"
  mediaUrl    String
  caption     String?
  collegeTag  String?  // The tagged college name/ID
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  likes       Like[]
  saves       Save[]
  comments    Comment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Like {
  id      String @id @default(uuid())
  userId  String
  postId  String
  user    User   @relation(fields: [userId], references: [id])
  post    Post   @relation(fields: [postId], references: [id])
  @@unique([userId, postId])
}

model Save {
  id      String @id @default(uuid())
  userId  String
  postId  String
  user    User   @relation(fields: [userId], references: [id])
  post    Post   @relation(fields: [postId], references: [id])
  @@unique([userId, postId])
}

model Grievance {
  id          String   @id @default(uuid())
  college     String
  issueType   String
  description String
  status      String   @default("pending")
  agrees      Int      @default(0)
  isAnonymous Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  comments    Comment[]
  agrees_list GrievanceAgree[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GrievanceAgree {
  id          String    @id @default(uuid())
  userId      String
  grievanceId String
  user        User      @relation(fields: [userId], references: [id])
  grievance   Grievance @relation(fields: [grievanceId], references: [id])
  @@unique([userId, grievanceId])
}

model Comment {
  id          String     @id @default(uuid())
  text        String
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  grievanceId String?
  grievance   Grievance? @relation(fields: [grievanceId], references: [id])
  postId      String?
  post        Post?      @relation(fields: [postId], references: [id])
  createdAt   DateTime   @default(now())
}

model Partner {
  id           String   @id @default(uuid())
  name         String
  email        String
  organization String
  website      String?
  message      String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
